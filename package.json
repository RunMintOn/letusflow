{
  "name": "diagram-editor-mvp",
  "displayName": "Diagram Editor MVP",
  "description": "VS Code MVP for a custom diagram DSL with a layout sidecar.",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/extension.cjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:diagramEditor.openPreview"
  ],
  "contributes": {
    "commands": [
      {
        "command": "diagramEditor.openPreview",
        "title": "Diagram Editor: Open Preview"
      }
    ]
  },
  "scripts": {
    "build:webview": "node esbuild.webview.mjs",
    "build": "npm run build:webview",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
