{
  "name": "letusflow",
  "displayName": "LetusFlow",
  "description": "A VS Code extension for editing and previewing flow diagram DSL with automatic layout.",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "author": "RunMintOn",
  "main": "./src/extension.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RunMintOn/letusflow.git"
  },
  "bugs": {
    "url": "https://github.com/RunMintOn/letusflow/issues"
  },
  "homepage": "https://github.com/RunMintOn/letusflow#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:diagramEditor.flowEditor"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "diagramEditor.flowEditor",
        "displayName": "Flow Diagram Editor",
        "selector": [
          {
            "filenamePattern": "*.flow"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build:webview": "node esbuild.webview.mjs",
    "build": "npm run build:webview",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.0",
    "dagre": "^0.8.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
